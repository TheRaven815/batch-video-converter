# Video Converter — Environment Configuration
# Copy this file to .env and adjust values for your deployment.

# Storage backend: "redis" for Docker/production, "local" for local SQLite development
VIDEO_CONVERTER_STORAGE=redis

# Redis connection URL (only used when VIDEO_CONVERTER_STORAGE=redis)
REDIS_URL=redis://redis:6379/0

# Root directory for runtime data (inputs, outputs, temp, logs, SQLite data)
DATA_ROOT=/data

# Media roots available for browsing in the UI
# Format: Label=/container/path;Label2=/container/path2
# If empty, defaults to DATA_ROOT/input
MEDIA_MOUNTS=Movies=/media/movies;Series=/media/series

# Number of concurrent job processing threads in the worker (default: 1)
# Increase for parallel FFmpeg jobs; requires proportional CPU/RAM resources.
# On Raspberry Pi or constrained environments, keep at 1.
# WORKER_CONCURRENCY=1
