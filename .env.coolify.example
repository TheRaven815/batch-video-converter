# Video Converter — Coolify deployment environment
# Adjust paths below to match your Raspberry Pi / server host paths.
# Media paths must match the volume mounts in docker-compose.coolify.yml.

VIDEO_CONVERTER_STORAGE=redis
REDIS_URL=redis://redis:6379/0
DATA_ROOT=/data
MEDIA_MOUNTS=Movies=/media/movies;TV Series=/media/tv-series;Downloads=/media/downloads
